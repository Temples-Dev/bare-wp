{
    "name": "bare-wp/ui-engine",
    "description": "Custom PHP UI engine for BARE-WP headless WordPress setup.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "BareWP\\": "src/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
